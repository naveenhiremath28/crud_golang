	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Run only for successful responses",
									"if (pm.response.code === 200) {",
									"    const jsonData = pm.response.json();",
									"",
									"    if (jsonData.access_token) {",
									"        // Save access token",
									"        pm.environment.set(\"access_token\", jsonData.access_token);",
									"        console.log(jsonData.access_token)",
									"        // (Optional) Save refresh token",
									"        if (jsonData.refresh_token) {",
									"            pm.environment.set(\"refresh_token\", jsonData.refresh_token);",
									"        }",
									"",
									"        // (Optional) Save expiry info",
									"        if (jsonData.expires_in) {",
									"            pm.environment.set(\"access_token_expires_in\", jsonData.expires_in);",
									"        }",
									"",
									"        console.log(\"Bearer token updated successfully\");",
									"    } else {",
									"        console.warn(\"access_token not found in response\");",
									"    }",
									"} else {",
									"    console.error(\"Login failed, token not updated\");",
									"}",
									""
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"id\": \"api.request\",\n  \"ver\": \"v1\",\n  \"ts\": \"2025-12-05T10:50:00Z\",\n  \"params\": {\n    \"msgid\": \"a7ef13d9-9e43-4fbe-9e56-c05b25e2e5b1\"\n  },\n  \"request\": {\n    \"username\": \"admin\",\n    \"password\": \"admin\"\n  }\n}\n",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/api/login",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
